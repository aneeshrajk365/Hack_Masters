          <button class="role-tab" onclick="setRole(this,'faculty')" type="button">
            <span class="rt-icon">📚</span><span class="rt-label">Faculty</span>
          </button>
          <button class="role-tab" onclick="setRole(this,'staff')" type="button">
            <span class="rt-icon">🏢</span><span class="rt-label">Staff</span>
          </button>
          <button class="role-tab" onclick="setRole(this,'admin')" type="button">
            <span class="rt-icon">⚙️</span><span class="rt-label">Admin</span>
