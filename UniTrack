<!-- ══════════════════ SCRIPTS ══════════════════ -->
<script>
/* ── Login UI helpers ── */
let selectedRole = 'student';

function setRole(el, role) {
  selectedRole = role;
  document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  const placeholders = {
    student: 'studentid@university.edu',
    faculty: 'faculty@university.edu',
    staff: 'staff@university.edu',
    admin: 'admin@university.edu'
  };
  document.getElementById('l-email').placeholder = placeholders[role] || 'you@university.edu';
}

function togglePass() {
  const f = document.getElementById('l-pass');
  const b = document.getElementById('pass-toggle');
  if (f.type === 'password') { f.type = 'text'; b.textContent = '🙈'; }
  else { f.type = 'password'; b.textContent = '👁'; }
}

/* ── Platform data ── */
const cats = [
  {label:'Infrastructure',color:'#534AB7',bg:'#EEEDFE'},
  {label:'IT & technology',color:'#085041',bg:'#E1F5EE'},
  {label:'Academic services',color:'#712B13',bg:'#FAECE7'},
  {label:'Hostel & housing',color:'#72243E',bg:'#FBEAF0'},
  {label:'Safety & security',color:'#791F1F',bg:'#FCEBEB'},
  {label:'Cleanliness',color:'#633806',bg:'#FAEEDA'},
  {label:'Other',color:'#444441',bg:'#F1EFE8'},
];
let selCat = cats[0].label;

const seed = [
  {id:'#1042',title:'Broken AC in Block C lab',cat:'Infrastructure',loc:'Block C, Room 204',desc:'The air conditioning unit has been non-functional for two weeks, severely affecting afternoon sessions.',status:'open',priority:'High',reporter:'Priya S.',role:'student',assigned:'',ts:'2025-04-10'},
  {id:'#1041',title:'Wi-Fi down in library basement',cat:'IT & technology',loc:'Central Library, B1',desc:'No connectivity on B1 floor. Both eduroam and guest networks are affected.',status:'In progress',priority:'Medium',reporter:'Rajan M.',role:'faculty',assigned:'IT Helpdesk',ts:'2025-04-08'},
  {id:'#1039',title:'Broken benches in courtyard',cat:'Infrastructure',loc:'Main Courtyard',desc:'Three wooden benches are cracked and pose a safety risk.',status:'Resolved',priority:'Low',reporter:'Fatima K.',role:'student',assigned:'Facilities',ts:'2025-04-05'},
  {id:'#1038',title:'Unclean washrooms near Canteen 2',cat:'Cleanliness',loc:'Canteen Block 2',desc:'Washrooms have not been cleaned since Monday morning.',status:'open',priority:'High',reporter:'Arjun T.',role:'staff',assigned:'',ts:'2025-04-12'},
  {id:'#1036',title:'Projector fault in Seminar Hall A',cat:'IT & technology',loc:'Seminar Hall A',desc:'HDMI port on main projector is damaged, disrupting classes.',status:'In progress',priority:'Medium',reporter:'Dr. Meera N.',role:'faculty',assigned:'AV Team',ts:'2025-04-07'},
];

let issues = JSON.parse(localStorage.getItem('ut2_issues') || 'null') || seed;
let notifs = JSON.parse(localStorage.getItem('ut2_notifs') || 'null') || [
  {msg:'Your complaint #1042 has been assigned to the Facilities team.',read:false,ts:'2025-04-11'},
  {msg:'Issue #1042 status updated to In progress.',read:false,ts:'2025-04-12'},
  {msg:'Complaint #1039 has been resolved. Thanks for reporting!',read:true,ts:'2025-04-06'},
];
let currentRole = 'student', currentUser = 'Priya S.', prevPage = 'home';

function save() {
  localStorage.setItem('ut2_issues', JSON.stringify(issues));
  localStorage.setItem('ut2_notifs', JSON.stringify(notifs));
}

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 2600);
}

function statusBadge(s) {
  if (s === 'open') return `<span class="badge b-open">${s}</span>`;
  if (s === 'Resolved') return `<span class="badge b-res">${s}</span>`;
  return `<span class="badge b-prog">${s}</span>`;
}
function prioBadge(p) {
  const cls = p === 'High' ? 'b-high' : p === 'Low' ? 'b-low' : 'b-med';
  return `<span class="badge ${cls}">${p}</span>`;
}

/* ── Login with animated button ── */
function doLogin() {
  const btn = document.getElementById('login-btn');
  btn.innerHTML = 'Signing in…';
  btn.style.background = 'var(--indigo-dark)';
  btn.disabled = true;

  setTimeout(() => {
    btn.innerHTML = '✓ &nbsp;Signed in — redirecting';
    btn.style.background = '#16A34A';

    setTimeout(() => {
      // Reset button for next time
      btn.innerHTML = 'Sign in <span class="btn-arrow">→</span>';
      btn.style.background = '';
      btn.disabled = false;

      // Do actual login
      const role = selectedRole;
      const email = document.getElementById('l-email').value || 'user@university.edu';
      currentRole = role;
      const names = {student:'Priya S.',faculty:'Dr. Meera N.',staff:'Rajan M.',admin:'Admin'};
      currentUser = names[role];
      document.getElementById('topbar').style.display = 'flex';
      document.getElementById('tb-role-label').textContent = email;
      buildNav();
      if (role === 'admin') showTab('admin'); else showTab('home');
    }, 800);
  }, 1200);
}

function buildNav() {
  const c = document.getElementById('tb-nav');
  c.innerHTML = '';
  const tabs = currentRole === 'admin'
    ? [['admin','Dashboard'],['notifications','Alerts']]
    : [['home','Home'],['myissues','My issues'],['report','New complaint'],['notifications','Notifications']];
  tabs.forEach(([id, label]) => {
    const b = document.createElement('button');
    b.className = 'nav-pill'; b.textContent = label;
    b.setAttribute('data-nt', id);
    b.onclick = () => showTab(id);
    c.appendChild(b);
  });
  const av = document.createElement('div');
  av.className = 'avatar';
  av.textContent = currentUser.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
  c.appendChild(av);
  const out = document.createElement('button');
  out.className = 'nav-pill'; out.textContent = 'Sign out';
  out.onclick = () => {
    document.getElementById('topbar').style.display = 'none';
    showPage('login');
    // Reset role tabs
    document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
    document.querySelector('.role-tab').classList.add('active');
    selectedRole = 'student';
  };
  c.appendChild(out);
}

function showTab(id) {
  document.querySelectorAll('[data-nt]').forEach(b => b.classList.toggle('active', b.getAttribute('data-nt') === id));
  if (id === 'home') { renderHome(); showPage('home'); }
  else if (id === 'report') { buildCatChips(); showPage('report'); }
  else if (id === 'myissues') { renderMy(); showPage('myissues'); }
  else if (id === 'notifications') { renderNotifs(); showPage('notifications'); }
  else if (id === 'admin') { renderAdmin('all'); showPage('admin'); }
}

function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
}

function buildCatChips() {
  const el = document.getElementById('cat-chips');
  el.innerHTML = cats.map(c => `
    <div class="cat-chip" onclick="pickCat('${c.label}',this)"
      style="background:${c.label===selCat?c.color:c.bg};color:${c.label===selCat?'#fff':c.color};border-color:${c.color}">
      ${c.label}
    </div>`).join('');
}

function pickCat(label, el) { selCat = label; buildCatChips(); }

function renderHome() {
  const mine = issues.filter(i => i.reporter === currentUser);
  const open = mine.filter(i => i.status === 'open').length;
  const prog = mine.filter(i => i.status === 'In progress').length;
  const res  = mine.filter(i => i.status === 'Resolved').length;
  const unread = notifs.filter(n => !n.read).length;
  document.getElementById('hero-greeting').textContent = `Hello, ${currentUser.split(' ')[0]}!`;
  document.getElementById('home-metrics').innerHTML = `
    <div class="metric-tile mt-purple"><div class="m-label">My open</div><div class="m-val">${open}</div><div class="m-icon">&#9679;</div></div>
    <div class="metric-tile mt-teal"><div class="m-label">In progress</div><div class="m-val">${prog}</div><div class="m-icon">&#9650;</div></div>
    <div class="metric-tile mt-coral"><div class="m-label">Resolved</div><div class="m-val">${res}</div><div class="m-icon">&#10003;</div></div>
    <div class="metric-tile mt-red"><div class="m-label">Unread alerts</div><div class="m-val">${unread}</div><div class="m-icon">&#9679;</div></div>`;
  const recent = mine.slice(0, 4);
  document.getElementById('home-recent').innerHTML = recent.length ? recent.map(i => `
    <div class="issue-row" onclick="viewIssue('${i.id}')">
      <span class="issue-id">${i.id}</span>
      <span class="issue-title">${i.title}</span>
      ${statusBadge(i.status)}
      ${prioBadge(i.priority)}
    </div>`).join('') : `<div style="color:var(--color-text-secondary);font-size:14px;padding:6px 0">No complaints yet. Click "+ New complaint" to file one.</div>`;
}

function renderMy() {
  const mine = issues.filter(i => i.reporter === currentUser);
  document.getElementById('my-count').textContent = `${mine.length} complaint${mine.length !== 1 ? 's' : ''}`;
  document.getElementById('my-list').innerHTML = mine.length ? mine.map(i => `
    <div class="issue-row" onclick="viewIssue('${i.id}')">
      <span class="issue-id">${i.id}</span>
      <span class="issue-title">${i.title}</span>
      <span class="issue-cat">${i.cat}</span>
      ${statusBadge(i.status)}
      ${prioBadge(i.priority)}
      <span style="font-size:12px;color:var(--color-text-secondary)">${i.ts}</span>
    </div>`).join('') : `<div style="color:var(--color-text-secondary);font-size:14px;padding:6px 0">No complaints filed yet.</div>`;
}

function renderNotifs() {
  document.getElementById('notif-list').innerHTML = notifs.map((n, i) => `
    <div class="notif-item ${n.read ? '' : 'unread'}" onclick="markRead(${i})" style="cursor:pointer">
      <div class="notif-dot ${n.read ? 'nd-read' : 'nd-unread'}"></div>
      <div style="flex:1">
        <div style="font-size:14px;font-weight:${n.read ? '400' : '500'};color:${n.read ? 'var(--color-text-secondary)' : '#26215C'}">${n.msg}</div>
        <div style="font-size:12px;color:#888780;margin-top:3px">${n.ts}</div>
      </div>
    </div>`).join('');
}
function markRead(i) { notifs[i].read = true; save(); renderNotifs(); }

function renderAdmin(filter) {
  let list = filter === 'all' ? issues : issues.filter(i => i.status === filter);
  const open = issues.filter(i => i.status === 'open').length;
  const prog = issues.filter(i => i.status === 'In progress').length;
  const res  = issues.filter(i => i.status === 'Resolved').length;
  const high = issues.filter(i => i.priority === 'High').length;
  document.getElementById('admin-metrics').innerHTML = `
    <div class="metric-tile mt-purple"><div class="m-label">Open</div><div class="m-val">${open}</div></div>
    <div class="metric-tile mt-teal"><div class="m-label">In progress</div><div class="m-val">${prog}</div></div>
    <div class="metric-tile" style="background:#639922"><div class="m-label">Resolved</div><div class="m-val">${res}</div></div>
    <div class="metric-tile mt-red"><div class="m-label">High priority</div><div class="m-val">${high}</div></div>`;
  document.getElementById('admin-list').innerHTML = list.length ? list.map(i => `
    <div class="issue-row" onclick="viewIssue('${i.id}')">
      <span class="issue-id">${i.id}</span>
      <span class="issue-title">${i.title}</span>
      <span class="issue-cat">${i.cat}</span>
      ${statusBadge(i.status)}
      ${prioBadge(i.priority)}
      <span class="issue-assign">${i.assigned || 'Unassigned'}</span>
      <span style="font-size:12px;color:var(--color-text-secondary)">${i.ts}</span>
    </div>`).join('') : `<div style="color:var(--color-text-secondary);font-size:14px;padding:6px 0">No issues in this filter.</div>`;
}

function aFilter(f, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderAdmin(f);
}

function submitComplaint() {
  const title = document.getElementById('r-title').value.trim();
  if (!title) { toast('Please enter an issue title.'); return; }
  const newId = '#' + (1000 + issues.length + 43);
  issues.unshift({
    id: newId, title, cat: selCat,
    loc: document.getElementById('r-loc').value || 'Not specified',
    desc: document.getElementById('r-desc').value || '',
    status: 'open', priority: document.getElementById('r-pri').value,
    reporter: currentUser, role: currentRole, assigned: '',
    ts: new Date().toISOString().slice(0, 10)
  });
  notifs.unshift({msg:`Your complaint ${newId} — "${title}" — has been submitted and is under review.`,read:false,ts:new Date().toISOString().slice(0,10)});
  save();
  document.getElementById('r-title').value = '';
  document.getElementById('r-desc').value = '';
  document.getElementById('r-loc').value = '';
  toast('Complaint submitted! You will be notified when it moves forward.');
  showTab('myissues');
}

function viewIssue(id) {
  prevPage = currentRole === 'admin' ? 'admin' : 'home';
  const i = issues.find(x => x.id === id);
  const isAdmin = currentRole === 'admin';
  const c = cats.find(x => x.label === i.cat) || cats[0];
  document.getElementById('detail-body').innerHTML = `
    <div class="card" style="border-top:4px solid ${c.color}">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:16px">
        <div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <span style="font-size:12px;font-weight:500;background:${c.bg};color:${c.color};padding:3px 9px;border-radius:20px">${i.cat}</span>
            <span style="font-size:12px;color:var(--color-text-secondary)">${i.id} · ${i.ts}</span>
          </div>
          <div style="font-size:19px;font-weight:500;color:#26215C">${i.title}</div>
        </div>
        <div style="display:flex;gap:6px;flex-wrap:wrap">${statusBadge(i.status)}${prioBadge(i.priority)}</div>
      </div>
      <div class="grid2" style="margin-bottom:14px">
        <div style="background:#EEEDFE;border-radius:10px;padding:12px">
          <div style="font-size:11px;font-weight:500;color:var(--p);margin-bottom:3px;letter-spacing:.5px">LOCATION</div>
          <div style="font-size:14px;color:#26215C">${i.loc}</div>
        </div>
        <div style="background:#E1F5EE;border-radius:10px;padding:12px">
          <div style="font-size:11px;font-weight:500;color:var(--t);margin-bottom:3px;letter-spacing:.5px">REPORTED BY</div>
          <div style="font-size:14px;color:#085041">${i.reporter} <span style="font-size:12px;color:#1D9E75">(${i.role})</span></div>
        </div>
      </div>
      <div style="font-size:13px;font-weight:500;color:#534AB7;margin-bottom:5px">Description</div>
      <div style="font-size:14px;line-height:1.65;color:var(--color-text-primary);margin-bottom:${isAdmin?'18px':'0'}">${i.desc}</div>
      ${isAdmin ? `
      <div class="pf-divider"></div>
      <div style="font-size:13px;font-weight:500;color:#534AB7;margin-bottom:12px">Admin controls</div>
      <div class="grid2" style="margin-bottom:14px">
        <div class="pf-field" style="margin-bottom:0">
          <label>Status</label>
          <select id="d-status">
            <option ${i.status==='open'?'selected':''}>open</option>
            <option ${i.status==='In progress'?'selected':''}>In progress</option>
            <option ${i.status==='Resolved'?'selected':''}>Resolved</option>
          </select>
        </div>
        <div class="pf-field" style="margin-bottom:0">
          <label>Priority</label>
          <select id="d-prio">
            <option ${i.priority==='Low'?'selected':''}>Low</option>
            <option ${i.priority==='Medium'?'selected':''}>Medium</option>
            <option ${i.priority==='High'?'selected':''}>High</option>
          </select>
        </div>
      </div>
      <div class="pf-field">
        <label>Assign to team</label>
        <select id="d-assign">
          <option value="">Unassigned</option>
          <option ${i.assigned==='Facilities'?'selected':''}>Facilities</option>
          <option ${i.assigned==='IT Helpdesk'?'selected':''}>IT Helpdesk</option>
          <option ${i.assigned==='AV Team'?'selected':''}>AV Team</option>
          <option ${i.assigned==='Hostel Office'?'selected':''}>Hostel Office</option>
          <option ${i.assigned==='Security'?'selected':''}>Security</option>
          <option ${i.assigned==='Housekeeping'?'selected':''}>Housekeeping</option>
        </select>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:6px">
        <button class="btn primary" onclick="saveIssue('${i.id}')">Save &amp; notify reporter</button>
      </div>` : ''}
    </div>`;
  showPage('detail');
}

function saveIssue(id) {
  const i = issues.find(x => x.id === id);
  const ns = document.getElementById('d-status').value;
  const np = document.getElementById('d-prio').value;
  const na = document.getElementById('d-assign').value;
  const changes = [];
  if (ns !== i.status) { changes.push(`status updated to "${ns}"`); i.status = ns; }
  if (np !== i.priority) { changes.push(`priority set to ${np}`); i.priority = np; }
  if (na !== i.assigned) { changes.push(`assigned to ${na || 'none'}`); i.assigned = na; }
  if (changes.length) {
    notifs.unshift({msg:`Issue ${id}: ${changes.join(', ')}.`,read:false,ts:new Date().toISOString().slice(0,10)});
    save(); toast('Saved! Reporter has been notified.');
  } else toast('No changes detected.');
}

function goBack() {
  if (prevPage === 'admin') { renderAdmin('all'); showPage('admin'); }
  else { renderHome(); showPage('home'); }
}
</script>
</body>
</html>
