        <button class="sso-btn" type="button">
          <div class="sso-icon">G</div>
          Sign in with university SSO
        </button>

        <!-- Privacy -->
        <div class="privacy-note">
          <strong>Your privacy is protected.</strong> Complaints are handled confidentially. Your identity will not be disclosed to the subject of a complaint without your consent and in accordance with university policy.
        </div>

        <!-- Status -->
        <div class="status-strip">
          <span class="status-dot"></span>
          All systems operational &nbsp;·&nbsp; Need help? <a href="#" style="color:var(--indigo);text-decoration:none;margin-left:4px">Contact support</a>
        </div>
        <div style="text-align:center;font-size:12px;color:var(--slate-400);margin-top:10px">Demo mode — select any role and sign in</div>

      </div>
    </div>
  </div>
</div>

