<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>UniTrack — Campus Resolution Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet"/>
<style>
/* ── RESET & TOKENS ── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  /* Login palette */
  --indigo:#4F46E5;--indigo-dark:#3730A3;--indigo-deep:#312E81;
  --indigo-light:#EEF2FF;--indigo-mid:#C7D2FE;
  --teal:#0D9488;--teal-light:#CCFBF1;
  --slate-900:#0F172A;--slate-800:#1E293B;--slate-700:#334155;--slate-600:#475569;
  --slate-400:#94A3B8;--slate-200:#E2E8F0;--slate-100:#F1F5F9;--slate-50:#F8FAFC;
  --white:#fff;
  --radius-sm:8px;--radius-md:12px;--radius-lg:18px;--radius-xl:24px;
  --shadow-sm:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --shadow-md:0 4px 16px rgba(79,70,229,.10),0 1px 4px rgba(0,0,0,.06);
  --shadow-lg:0 12px 40px rgba(79,70,229,.15),0 2px 8px rgba(0,0,0,.08);
  --font-display:'Playfair Display',Georgia,serif;
  --font-ui:'DM Sans',system-ui,sans-serif;
  --font-mono:'JetBrains Mono',monospace;

  /* Platform palette */
  --p:#7F77DD;--p-light:#EEEDFE;--p-dark:#3C3489;--p-text:#26215C;
  --t:#1D9E75;--t-light:#E1F5EE;--t-dark:#085041;
  --coral:#D85A30;--amber:#BA7517;--amber-light:#FAEEDA;
  --red:#E24B4A;--red-light:#FCEBEB;
  --green:#639922;--green-light:#EAF3DE;--green-text:#27500A;
  --pink:#D4537E;

  /* Shared */
  --color-background-primary:#ffffff;
  --color-background-tertiary:#F4F3FD;
  --color-text-primary:#1E1B3A;
  --color-text-secondary:#6B6892;
  --font-sans:'DM Sans',system-ui,sans-serif;
}
html,body{height:100%;font-family:var(--font-ui);background:var(--color-background-tertiary);color:var(--slate-800)}

/* ═══════════════════════════════════
   LOGIN PAGE
═══════════════════════════════════ */
.login-page{display:grid;grid-template-columns:1fr 1fr;min-height:100vh}
@media(max-width:860px){.login-page{grid-template-columns:1fr}}

/* Left panel */
.lp-left{
  background:var(--indigo-deep);
  position:relative;overflow:hidden;
  display:flex;flex-direction:column;justify-content:space-between;
  padding:48px 52px;
}
@media(max-width:860px){.lp-left{display:none}}

.geo{position:absolute;border-radius:50%;opacity:.12}
.geo-1{width:360px;height:360px;background:#818CF8;top:-80px;right:-100px}
.geo-2{width:220px;height:220px;background:#A5B4FC;bottom:120px;right:80px}
.geo-3{width:140px;height:140px;background:#C7D2FE;bottom:-40px;left:60px}
.geo-line{position:absolute;width:1px;height:100%;background:linear-gradient(180deg,transparent 0%,rgba(165,180,252,.4) 40%,rgba(165,180,252,.4) 60%,transparent 100%);left:38%}

.left-brand{display:flex;align-items:center;gap:12px;z-index:1;position:relative}
.brand-mark{
  width:42px;height:42px;border-radius:var(--radius-sm);
  background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.25);
  display:flex;align-items:center;justify-content:center;
}
.brand-name{font-family:var(--font-display);font-size:22px;color:#fff;letter-spacing:.3px}
.brand-tagline{font-size:12px;color:#A5B4FC;margin-top:1px}

.left-body{z-index:1;position:relative;flex:1;display:flex;flex-direction:column;justify-content:center;padding:40px 0}
.left-headline{font-family:var(--font-display);font-size:38px;line-height:1.2;color:#fff;margin-bottom:18px}
.left-headline span{color:#A5B4FC}
.left-sub{font-size:15px;color:#C7D2FE;line-height:1.65;max-width:340px;margin-bottom:40px}

.illustration{
  width:100%;max-width:320px;border-radius:var(--radius-lg);
  background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);
  padding:28px;display:flex;flex-direction:column;gap:12px;
}
.ill-bar{height:8px;border-radius:4px;background:rgba(255,255,255,.15)}
.ill-bar.w60{width:60%}.ill-bar.w80{width:80%}.ill-bar.w45{width:45%}
.ill-row{display:flex;gap:10px;align-items:center}
.ill-dot{width:28px;height:28px;border-radius:50%;flex-shrink:0}
.ill-dot.purple{background:rgba(165,180,252,.5)}
.ill-dot.teal{background:rgba(94,234,212,.4)}
.ill-dot.amber{background:rgba(252,211,77,.4)}
.ill-lines{flex:1;display:flex;flex-direction:column;gap:5px}
.ill-line{height:6px;border-radius:3px;background:rgba(255,255,255,.12)}
.ill-line.sh{width:60%}

.trust-list{z-index:1;position:relative;display:flex;flex-direction:column;gap:10px}
.trust-item{display:flex;align-items:center;gap:10px;font-size:13px;color:#C7D2FE}
.trust-icon{
  width:26px;height:26px;border-radius:6px;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px;
}

/* Right panel */
.lp-right{
  display:flex;align-items:center;justify-content:center;
  padding:40px 32px;background:var(--white);
}
@media(max-width:860px){
  .lp-right{background:var(--indigo-deep);align-items:flex-start;padding:32px 20px}
}

.login-card{
  width:100%;max-width:440px;background:var(--white);
  border-radius:var(--radius-xl);box-shadow:var(--shadow-lg);
  padding:40px 36px;
  animation:slideUp .5s cubic-bezier(.16,1,.3,1) both;
}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:860px){.login-card{padding:28px 24px}}

.card-top{margin-bottom:28px}
.card-logo{display:none;align-items:center;gap:10px;margin-bottom:20px}
@media(max-width:860px){.card-logo{display:flex}}
.card-logo .brand-mark{background:var(--indigo);border-color:var(--indigo-dark)}
.card-logo .brand-name{color:var(--slate-800)}
.card-logo .brand-tagline{color:var(--slate-400)}
.card-title{font-family:var(--font-display);font-size:26px;color:var(--slate-900);margin-bottom:6px}
.card-sub{font-size:14px;color:var(--slate-400);line-height:1.5}

/* Role tabs */
.role-label{font-size:12px;font-weight:600;color:var(--slate-600);letter-spacing:.6px;text-transform:uppercase;margin-bottom:10px}
.role-tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:24px}
.role-tab{
  display:flex;flex-direction:column;align-items:center;gap:5px;
  padding:10px 6px;border-radius:var(--radius-md);
  border:1.5px solid var(--slate-200);background:var(--white);
  cursor:pointer;transition:all .18s;
}
.role-tab:hover{border-color:var(--indigo-mid);background:var(--indigo-light)}
.role-tab.active{border-color:var(--indigo);background:var(--indigo-light)}
.role-tab .rt-icon{font-size:18px;line-height:1}
.role-tab .rt-label{font-size:11px;font-weight:500;color:var(--slate-600);transition:color .18s}
.role-tab.active .rt-label{color:var(--indigo-dark);font-weight:600}

/* Form fields */
.field{margin-bottom:18px}
.field-label{
  display:flex;justify-content:space-between;align-items:center;
  font-size:13px;font-weight:500;color:var(--slate-700);margin-bottom:7px;
}
.field-label a{font-size:12px;color:var(--indigo);text-decoration:none;font-weight:400}
.field-label a:hover{text-decoration:underline}
.field-wrap{position:relative}
.field-icon{
  position:absolute;left:13px;top:50%;transform:translateY(-50%);
  font-size:15px;pointer-events:none;opacity:.5;
}
.field-input{
  width:100%;height:46px;padding:0 14px 0 40px;
  border:1.5px solid var(--slate-200);border-radius:var(--radius-md);
  font-family:var(--font-ui);font-size:15px;color:var(--slate-900);
  background:var(--slate-50);outline:none;
  transition:border-color .18s,box-shadow .18s,background .18s;
}
.field-input:focus{border-color:var(--indigo);background:var(--white);box-shadow:0 0 0 3px rgba(79,70,229,.12)}
.field-input::placeholder{color:var(--slate-400)}
.pass-toggle{
  position:absolute;right:13px;top:50%;transform:translateY(-50%);
  background:none;border:none;cursor:pointer;
  font-size:15px;color:var(--slate-400);padding:4px;transition:color .15s;
}
.pass-toggle:hover{color:var(--indigo)}

.remember-row{display:flex;align-items:center;gap:8px;margin-bottom:22px}
.remember-row input[type=checkbox]{width:16px;height:16px;accent-color:var(--indigo);cursor:pointer}
.remember-row label{font-size:13px;color:var(--slate-600);cursor:pointer}

.cta-btn{
  width:100%;height:50px;background:var(--indigo);color:#fff;
  font-family:var(--font-ui);font-size:15px;font-weight:600;
  border:none;border-radius:var(--radius-md);cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:background .18s,transform .12s,box-shadow .18s;
  box-shadow:0 2px 8px rgba(79,70,229,.3);position:relative;overflow:hidden;
}
.cta-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12) 0%,transparent 60%)}
.cta-btn:hover{background:var(--indigo-dark);box-shadow:0 4px 16px rgba(79,70,229,.4);transform:translateY(-1px)}
.cta-btn:active{transform:translateY(0)}
.btn-arrow{font-size:16px;transition:transform .18s}
.cta-btn:hover .btn-arrow{transform:translateX(3px)}

.l-divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--slate-400);font-size:12px}
.l-divider::before,.l-divider::after{content:'';flex:1;height:1px;background:var(--slate-200)}

.sso-btn{
  width:100%;height:44px;background:var(--white);color:var(--slate-800);
  font-family:var(--font-ui);font-size:14px;font-weight:500;
  border:1.5px solid var(--slate-200);border-radius:var(--radius-md);
  cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;
  transition:border-color .18s,background .18s;
}
.sso-btn:hover{border-color:var(--slate-400);background:var(--slate-50)}
.sso-icon{width:20px;height:20px;border-radius:4px;background:var(--indigo-light);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--indigo)}

.privacy-note{
  margin-top:20px;padding:14px 16px;background:var(--indigo-light);
  border-radius:var(--radius-md);border-left:3px solid var(--indigo);
  font-size:12px;color:var(--indigo-dark);line-height:1.55;
}
.privacy-note strong{font-weight:600}

.status-strip{display:flex;align-items:center;justify-content:center;gap:6px;font-size:12px;color:var(--slate-400);margin-top:20px;text-align:center}
.status-dot{width:7px;height:7px;border-radius:50%;background:#22C55E;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ═══════════════════════════════════
   PLATFORM (post-login)
═══════════════════════════════════ */
input,select,textarea{
  font-family:var(--font-sans);font-size:14px;color:var(--color-text-primary);
  background:var(--color-background-primary);border:1.5px solid #CECBF6;
  border-radius:10px;padding:9px 13px;width:100%;outline:none;transition:border-color .2s;
}
input:focus,select:focus,textarea:focus{border-color:var(--p);box-shadow:0 0 0 3px #EEEDFE}
textarea{resize:vertical}
.btn{
  font-family:var(--font-sans);font-size:14px;cursor:pointer;border-radius:10px;
  border:1.5px solid #CECBF6;background:var(--color-background-primary);
  color:var(--color-text-primary);padding:9px 18px;transition:all .15s;font-weight:500;
}
.btn:hover{background:#EEEDFE;border-color:var(--p);color:var(--p-dark)}
.btn.primary{background:var(--p);color:#fff;border-color:var(--p)}
.btn.primary:hover{background:var(--p-dark);border-color:var(--p-dark)}
.btn.teal{background:var(--t);color:#fff;border-color:var(--t)}
.btn.teal:hover{background:var(--t-dark)}
.btn.sm{font-size:12px;padding:5px 12px}

.badge{display:inline-block;font-size:11px;font-weight:500;padding:3px 9px;border-radius:20px;letter-spacing:.2px}
.b-open{background:#EEEDFE;color:#3C3489}
.b-prog{background:#FAEEDA;color:#633806}
.b-res{background:#EAF3DE;color:#27500A}
.b-high{background:#FCEBEB;color:#791F1F}
.b-med{background:#FAEEDA;color:#633806}
.b-low{background:#EAF3DE;color:#27500A}

.topbar{display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:56px;background:var(--p);color:#fff}
.topbar-brand{display:flex;align-items:center;gap:10px}
.brand-icon{width:30px;height:30px;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center}
.topbar-brand-name{font-size:16px;font-weight:500;color:#fff;letter-spacing:.3px}
.topbar-brand-tagline{font-size:11px;color:#CECBF6;margin-top:1px}
.topbar-right{display:flex;align-items:center;gap:10px}
.avatar{width:34px;height:34px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;color:var(--p-dark);flex-shrink:0}
.nav-pill{font-size:13px;font-weight:500;padding:6px 14px;border-radius:20px;background:transparent;color:#EEEDFE;border:1.5px solid rgba(255,255,255,.3);cursor:pointer;transition:all .15s}
.nav-pill:hover,.nav-pill.active{background:#fff;color:var(--p-dark);border-color:#fff}

.page{display:none;padding:24px;max-width:960px;margin:0 auto}
.page.active{display:block}

.section-label{font-size:12px;font-weight:500;color:var(--p);letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px}
.card{background:var(--color-background-primary);border-radius:16px;border:1.5px solid #EEEDFE;padding:20px}
.card.accent-purple{border-top:4px solid var(--p)}
.card.accent-teal{border-top:4px solid var(--t)}
.metric-tile{border-radius:14px;padding:16px 18px;color:#fff;position:relative;overflow:hidden}
.metric-tile .m-label{font-size:12px;opacity:.85;margin-bottom:6px}
.metric-tile .m-val{font-size:28px;font-weight:500}
.metric-tile .m-icon{position:absolute;right:14px;top:14px;font-size:22px;opacity:.35}
.mt-purple{background:var(--p)}.mt-teal{background:var(--t)}.mt-coral{background:var(--coral)}.mt-red{background:var(--red)}
.grid4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.pf-field{margin-bottom:14px}
.pf-field label{display:block;font-size:13px;font-weight:500;color:var(--p-dark);margin-bottom:5px}

.issue-row{display:flex;align-items:center;gap:10px;padding:13px 14px;border-radius:12px;cursor:pointer;transition:background .15s;font-size:14px}
.issue-row:hover{background:#EEEDFE}
.issue-id{font-size:11px;font-weight:500;color:var(--p);background:#EEEDFE;padding:2px 7px;border-radius:6px;min-width:52px;text-align:center}
.issue-title{flex:1;color:var(--color-text-primary);font-weight:500}
.issue-cat{font-size:11px;color:var(--color-text-secondary);min-width:90px}
.issue-assign{font-size:12px;color:var(--t-dark);min-width:90px}

.tab-bar{display:flex;gap:6px;margin-bottom:18px}
.tab{font-size:13px;padding:7px 16px;cursor:pointer;border-radius:20px;border:1.5px solid #EEEDFE;background:transparent;color:var(--color-text-secondary);font-weight:500;transition:all .15s}
.tab.active{background:var(--p);color:#fff;border-color:var(--p)}

.notif-item{display:flex;align-items:flex-start;gap:12px;padding:14px 16px;border-radius:12px;margin-bottom:8px;border:1.5px solid #EEEDFE;background:var(--color-background-primary)}
.notif-item.unread{border-color:#CECBF6;background:#EEEDFE}
.notif-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px}
.nd-unread{background:var(--p)}.nd-read{background:#D3D1C7}

.pf-divider{height:1px;background:#EEEDFE;margin:12px 0}
.toast{display:none;padding:11px 18px;background:var(--p);color:#fff;border-radius:10px;font-size:13px;font-weight:500;margin-bottom:16px;position:fixed;top:70px;left:50%;transform:translateX(-50%);z-index:999;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.15)}

.hero-strip{background:var(--p);border-radius:16px;padding:20px 24px;color:#fff;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between}
.hero-strip .hs-title{font-size:17px;font-weight:500}
.hero-strip .hs-sub{font-size:13px;color:#CECBF6;margin-top:3px}

.cat-chip{display:inline-block;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:500;cursor:pointer;border:1.5px solid transparent;transition:all .15s}
</style>
</head>
<body>

<!-- ══════════════════ TOAST ══════════════════ -->
<div id="toast" class="toast"></div>

<!-- ══════════════════ TOPBAR (hidden until login) ══════════════════ -->
<div id="topbar" class="topbar" style="display:none">
  <div class="topbar-brand">
    <div class="brand-icon">
      <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
        <rect x="2" y="8" width="14" height="8" rx="2" fill="#7F77DD"/>
        <path d="M9 2L16 7H2L9 2Z" fill="#534AB7"/>
        <rect x="7" y="10" width="4" height="6" rx="1" fill="white"/>
      </svg>
    </div>
    <div>
      <div class="topbar-brand-name">UniTrack</div>
      <div class="topbar-brand-tagline" id="tb-role-label">University Portal</div>
    </div>
  </div>
  <div class="topbar-right" id="tb-nav"></div>
</div>

<!-- ══════════════════ LOGIN PAGE ══════════════════ -->
<div id="page-login" class="page active" style="padding:0;max-width:none">
  <div class="login-page">

    <!-- LEFT PANEL -->
    <div class="lp-left">
      <div class="geo geo-1"></div>
      <div class="geo geo-2"></div>
      <div class="geo geo-3"></div>
      <div class="geo-line"></div>

      <div class="left-brand">
        <div class="brand-mark">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect x="3" y="10" width="16" height="10" rx="2.5" fill="rgba(255,255,255,.6)"/>
            <path d="M11 2L19 8.5H3L11 2Z" fill="white"/>
            <rect x="8.5" y="12.5" width="5" height="7.5" rx="1.5" fill="rgba(79,70,229,.8)"/>
          </svg>
        </div>
        <div>
          <div class="brand-name">UniTrack</div>
          <div class="brand-tagline">Campus Resolution Portal</div>
        </div>
      </div>

      <div class="left-body">
        <div class="left-headline">
          Your voice<br/><span>shapes the</span><br/>campus.
        </div>
        <div class="left-sub">
          Report issues, track resolutions, and hold your institution accountable — safely and transparently.
        </div>
        <div class="illustration">
          <div class="ill-bar w80"></div>
          <div class="ill-bar w60"></div>
          <div style="height:14px"></div>
          <div class="ill-row">
            <div class="ill-dot purple"></div>
            <div class="ill-lines"><div class="ill-line"></div><div class="ill-line sh"></div></div>
          </div>
          <div class="ill-row">
            <div class="ill-dot teal"></div>
            <div class="ill-lines"><div class="ill-line"></div><div class="ill-line sh"></div></div>
          </div>
          <div class="ill-row">
            <div class="ill-dot amber"></div>
            <div class="ill-lines"><div class="ill-line"></div><div class="ill-line sh"></div></div>
          </div>
          <div style="height:6px"></div>
          <div class="ill-bar w45"></div>
        </div>
      </div>

      <div class="trust-list">
        <div class="trust-item"><div class="trust-icon">🔒</div>Your identity is protected — reports are confidential</div>
        <div class="trust-item"><div class="trust-icon">✓</div>Average resolution time: 4.2 working days</div>
        <div class="trust-item"><div class="trust-icon">📋</div>1,240+ issues resolved this semester</div>
      </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="lp-right">
      <div class="login-card">

        <!-- Mobile logo -->
        <div class="card-logo">
          <div class="brand-mark" style="background:var(--indigo);border-color:var(--indigo-dark)">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <rect x="3" y="10" width="16" height="10" rx="2.5" fill="rgba(255,255,255,.7)"/>
              <path d="M11 2L19 8.5H3L11 2Z" fill="white"/>
              <rect x="8.5" y="12.5" width="5" height="7.5" rx="1.5" fill="rgba(79,70,229,.9)"/>
            </svg>
          </div>
          <div>
            <div class="brand-name" style="color:var(--slate-800)">UniTrack</div>
            <div class="brand-tagline" style="color:var(--slate-400)">Campus Resolution Portal</div>
          </div>
        </div>

        <div class="card-top">
          <div class="card-title">Welcome back</div>
          <div class="card-sub">Sign in to report an issue or check your complaint status.</div>
        </div>

        <!-- Role selector -->
        <div class="role-label">Sign in as</div>
        <div class="role-tabs">
          <button class="role-tab active" onclick="setRole(this,'student')" type="button">
            <span class="rt-icon">🎓</span><span class="rt-label">Student</span>
