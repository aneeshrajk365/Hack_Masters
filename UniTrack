        <!-- Email -->
        <div class="field">
          <div class="field-label">University email</div>
          <div class="field-wrap">
            <span class="field-icon">✉</span>
            <input class="field-input" type="email" id="l-email" placeholder="studentid@university.edu" autocomplete="email" value="priya@university.edu"/>
          </div>
        </div>

        <!-- Password -->
        <div class="field">
          <div class="field-label">
            Password
            <a href="#">Forgot password?</a>
          </div>
          <div class="field-wrap">
            <span class="field-icon">🔑</span>
            <input class="field-input" type="password" id="l-pass" placeholder="Enter your password" autocomplete="current-password" value="password"/>
            <button class="pass-toggle" type="button" onclick="togglePass()" id="pass-toggle" title="Show password">👁</button>
